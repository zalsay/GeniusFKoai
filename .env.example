# ===========================================================================
# 环境变量示例 —— 复制为 .env 后按需填写
#
#   cp .env.example .env
#
# 说明：
#   - 所有变量都是可选的，留空走代码内默认值或对应功能关闭。
#   - 第三方 API key 也可以在 Web UI「全局配置」里配置，二选一即可。
#   - 切勿把填好真实值的 .env 提交进 git（已在 .gitignore 忽略）。
# ===========================================================================

# ----- 主服务 -------------------------------------------------------------
# 访问密码：设置后所有 /api 请求需携带该密码（Bearer / 查询参数）。
# 公网部署强烈建议设置。留空 = 无密码保护。
APP_PASSWORD=
# 数据库连接串。默认使用项目根目录下的 account_manager.db。
# Docker 持久化示例：sqlite:////app/data/account_manager.db
ACCOUNT_MANAGER_DATABASE_URL=

# ----- Docker / noVNC ------------------------------------------------------
# headed 浏览器模式下 noVNC 的访问密码。留空 = 无密码。
VNC_PASSWORD=

# ----- 本地 Turnstile Solver ----------------------------------------------
# 本地 Camoufox solver 监听端口（默认 5073，容器内对外暴露 8889）。
SOLVER_PORT=

# ----- BitBrowser（比特浏览器，可选的浏览器后端）---------------------------
# 在 BitBrowser GUI 手工创建 profile 后填其 ID；UI 表单留空时回退到此变量。
BIT_PROFILE_ID=
# BitBrowser 本地 API 地址，默认 http://127.0.0.1:54345
BIT_API_URL=
# 企业版需要的 API token，社区版留空。
BIT_API_TOKEN=

# ----- ChatGPT Plus 协议结账 -----------------------------------------------
# 协议化结账实采开关（live 模式）。详见 platforms/chatgpt。
CHATGPT_PROTOCOL_CHECKOUT_LIVE=

# ----- 接码服务 API key（也可在 Web UI 配置）-------------------------------
# HeroSMS（GoPay 注册 / 印尼号默认渠道）
OPAI_HEROSMS_API_KEY=
# 从文件读取 HeroSMS key（与上面二选一，适合挂载 secret 文件）
OPAI_HEROSMS_API_KEY_FILE=
# SMSPool
OPAI_SMSPOOL_API_KEY=
OPAI_SMSPOOL_COUNTRY=9
OPAI_SMSPOOL_SERVICE=392
OPAI_SMSPOOL_MAX_PRICE=0.11
OPAI_SMSPOOL_PRICING_OPTION=0
# SMSBower
OPAI_SMSBOWER_API_KEY=
OPAI_SMSBOWER_COUNTRY=6
OPAI_SMSBOWER_SERVICE=ni

# ----- GoPay 付款 ChatGPT Plus（本项目扩展功能）----------------------------
# GoPay 账号默认 PIN（注册新号 / 付款时使用，可被任务参数 gopay_pin 覆盖）。
OPAI_GOPAY_DEFAULT_PIN=
# GoPay 注册 / 付款专用出口代理（留空走全局代理池）。
OPAI_GOPAY_REGISTER_PROXY=
# 旋转代理模板（含占位符的代理 URL 模板，按需填写）。
OPAI_GOPAY_PROXY_TEMPLATE=
# 付款前账号余额 / 时效相关阈值（一般保持默认即可）。
OPAI_GOPAY_MIN_BALANCE_RP=1
OPAI_GOPAY_MIN_REMAINING_SEC=300
OPAI_GOPAY_ACCOUNT_TTL_SEC=1200
OPAI_GOPAY_POLL_INTERVAL=10

# ----- GoPay Payment Inbox（可选，独立 worker 队列服务）--------------------
# 仅在使用 platforms/gopay-deploy 的独立 Inbox 服务时需要。不用则全部留空。
OPAI_PAYMENT_INBOX_BASE_URL=
OPAI_PAYMENT_INBOX_TOKEN=
OPAI_PAYMENT_INBOX_BASIC_USER=
OPAI_PAYMENT_INBOX_BASIC_PASS=
OPAI_PAYMENT_INBOX_HOST=0.0.0.0
OPAI_PAYMENT_INBOX_PORT=18130
OPAI_PAYMENT_INBOX_PATH=
OPAI_PAYMENT_INBOX_DB_PATH=
OPAI_PAYMENT_INBOX_RETENTION_SEC=604800
