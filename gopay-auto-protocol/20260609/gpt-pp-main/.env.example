# =================================================================
# PayPal 智能收单转化网关部署与运行环境变量配置模板 (.env.example)
# 使用方法：复制本文件并重命名为 .env，然后根据您的服务器实际配置填写以下内容。
# =================================================================

# 1. 自动化一键部署配置 (deploy_server.py / deploy_go_gateway.py)
DEPLOY_HOST=154.193.242.203           # 远程部署服务器公网 IP
DEPLOY_PORT=22                        # SSH 登录端口，默认 22
DEPLOY_USER=root                      # SSH 登录用户名
DEPLOY_PASSWORD=your_ssh_password     # SSH 登录密码/密钥短语
DEPLOY_DOMAIN=pp.1818.pro             # 网关绑定的防劫持域名

# 2. 网关安全域名与公网 IP 限制 (webapp/server.py)
# 允许访问网关控制台的主机域名列表，多个域名以英文逗号分隔（默认始终允许 localhost, 127.0.0.1）
ALLOWED_DOMAINS=pp.1818.pro,your-domain.com

# 本网关服务器的公网 IP。当家宽住宅代理需要免密 IP 白名单授权时，
# 鉴权失败的提示信息将动态包含此 IP，方便快速复制添加到代理后台。
SERVER_PUBLIC_IP=154.193.242.203

# 3. 其它运行期环境变量参数（可选自定义）
# PLUS_LINK_PROXY=socks5h://user:pass@proxy-host.example:1000
# PLUS_LINK_PORT=8888
# PLUS_LINK_REQUIRE_ZERO=0
